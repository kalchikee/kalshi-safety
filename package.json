{
  "name": "kalshi-safety",
  "version": "2.0.0",
  "description": "Central Kalshi betting service. Fetches predictions from sport repos, places + monitors bets, owns stop-loss and recap. Library entry (checkBet/recordPaperBet) retained for external callers.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit && echo 'Lint pass: tsc clean'"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "dependencies": {
    "dotenv": "^16.4.5",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}